# OpenRouter API key for LLM routing
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ArcadeDB connection
ARCADEDB_URL=http://localhost:2480
ARCADEDB_USER=root
ARCADEDB_PASSWORD=your-arcadedb-password

# PostgreSQL connection for LangGraph checkpoints
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Langfuse observability
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Project configuration path
AGENT_OPERATIONS_CONFIG_PATH=./config/reference

# Render API key (for future orchestration use)
RENDER_API_KEY=rnd-your-render-api-key
