# Secrets — never commit this file.
# Copy to .env and fill in your values.

# API key for your chosen LLM provider (required)
LLM_API_KEY=your-api-key-here

# Tavily web search (get a key at https://tavily.com/)
TAVILY_API_KEY=

# LLM settings (optional — defaults apply if not set)
# Model name follows LiteLLM convention: provider/model_name
# Default: openrouter/deepseek/deepseek-v4-pro
# LLM_MODEL=openrouter/deepseek/deepseek-v4-pro
# LLM_BASE_URL=

# Safety caps (optional — values below are the defaults)
# MAX_COST_USD=5.00
# MAX_ITERATIONS=500
# CONDENSER_MAX_SIZE=100

# Conversation persistence (optional — persistence is enabled by default)
# State is saved to PERSISTENCE_DIR/{conversation-id}/ so runs can be resumed.
# PERSISTENCE_DIR=.openhands/conversations
# RESUME_CONVERSATION_ID=   # UUID printed at the end of a previous run

# OpenRouter provider routing (optional — only applies when LLM_MODEL starts with openrouter/)
# Pin to one or more providers (comma-separated). Uses OpenRouter's provider routing API.
# Example: OPENROUTER_PROVIDERS=DeepSeek          → prefer official DeepSeek API
# Example: OPENROUTER_PROVIDERS=Fireworks,Together → try Fireworks first, then Together
# OPENROUTER_PROVIDERS=
# Set to false to fail rather than fall back to another provider if the preferred one is unavailable.
# OPENROUTER_ALLOW_FALLBACKS=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="https://your-otlp-collector:4317/v1/traces"
OTEL_EXPORTER_OTLP_TRACES_HEADERS="Authorization=Bearer%20YOUR_TOKEN"
OTEL_EXPORTER_OTLP_TRACES_PROTOCOL="http/protobuf"

# PromptFoo evaluations (evals/ directory)
OPENROUTER_API_KEY=your-openrouter-api-key
